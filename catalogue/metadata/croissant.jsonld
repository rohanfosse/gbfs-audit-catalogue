  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "gbfs-audit-catalogue",
  "description": "A certified, anomaly-flagged reference dataset of 46,307 bike-sharing stations across 123 French operators, with per-row audit verdicts (seven data-quality classes A1–A7) and contextual enrichment from INSEE, BAAC, BD TOPO, BD ALTI and the national GTFS aggregator.",
  "version": "1.0.1",
  "datePublished": "2026-05-13",
  "url": "https://gbfs-audit.streamlit.app",
  "license": "https://opendatacommons.org/licenses/odbl/1-0/",
  "citeAs": "Fossé, R. & Pallares, G. (2026). GBFS Audit Catalogue v1.0. Zenodo. https://doi.org/10.5281/zenodo.20125460",
  "keywords": [
    "GBFS",
    "bike-sharing",
    "open mobility data",
    "data quality",
    "FAIR",
    "standards compliance",
    "reproducibility",
    "smart city"
  ],
  "creator": [
    {
      "@type": "sc:Person",
      "name": "Fossé, Rohan"
    },
    {
      "@type": "sc:Person",
      "name": "Pallares, Gaël"
    }
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "catalogue-parquet",
      "name": "stations_gold_standard_final.parquet",
      "description": "Certified catalogue in Apache Parquet.",
      "contentUrl": "https://zenodo.org/records/20125460/files/stations_gold_standard_final.parquet",
      "encodingFormat": "application/vnd.apache.parquet",
      "contentSize": "6590752 B",
      "sha256": "a38e95a8ad525ef3a9a2d78ac9d7c14c57df276465e3e902874f32a0760b1c59"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "stations",
      "name": "stations",
      "description": "One record per certified station.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "stations/uid",
          "name": "uid",
          "description": "Audit Catalogue primary key (stable per certified station).",
